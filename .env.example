# Postgres
DATABASE_URL="postgresql://singlufest:CHANGE_ME@singlufest-db:5432/singlufest?schema=public"

# NextAuth
AUTH_SECRET="generate_with_openssl_rand_base64_32"
AUTH_URL="https://singlufest.hubstartidea.es"
NEXTAUTH_URL="https://singlufest.hubstartidea.es"

# Admin bootstrap (solo se usa en seed inicial; luego cambiar password desde panel)
ADMIN_EMAIL="mario@startidea.es"
ADMIN_PASSWORD="CHANGE_ME"

# Email (Resend recomendado, fallback SMTP)
RESEND_API_KEY=""
EMAIL_FROM="Singlufest <hola@singlufest.hubstartidea.es>"
EMAIL_REPLY_TO="hola@singlufest.hubstartidea.es"

# SMTP fallback (Hostinger u otro)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Captcha (hCaptcha)
NEXT_PUBLIC_HCAPTCHA_SITEKEY=""
HCAPTCHA_SECRET=""

# Cron secret (endpoint de publicación programada)
CRON_SECRET="generate_with_openssl_rand_base64_24"

# Anthropic (agentes IA)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# Telegram (notificaciones del analista semanal)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Umami analytics (compartido con resto del portfolio)
NEXT_PUBLIC_UMAMI_SCRIPT_URL="https://analytics.hubstartidea.es/script.js"
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""

# Feature flags
NEXT_PUBLIC_RESERVATIONS_OPEN="false"

# Container binding
HOSTNAME="0.0.0.0"
PORT="3000"
NODE_ENV="production"
