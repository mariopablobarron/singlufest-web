// Singlufest — schema inicial.
// Convención: todos los `id` son cuid(), timestamps en UTC.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  STAFF
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  WAITLIST
}

enum SponsorTier {
  DIAMOND
  GOLD
  SILVER
  BRONZE
  COLLAB
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum EventKind {
  SHOWCOOKING
  CHARLA
  CATA
  TALLER
  CONCIERTO
  MERCADO
  OTRO
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          Role      @default(EDITOR)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  posts         Post[]
  edition       Edition[] @relation("EditionCreatedBy")
}

model Edition {
  id          String   @id @default(cuid())
  year        Int      @unique
  slug        String   @unique
  title       String
  subtitle    String?
  startsAt    DateTime?
  endsAt      DateTime?
  venue       String?
  address     String?
  city        String   @default("Granada")
  country     String   @default("España")
  description String?  @db.Text
  isCurrent   Boolean  @default(false)
  isPublished Boolean  @default(false)
  createdById String?
  createdBy   User?    @relation("EditionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events      Event[]
  reservations Reservation[]
  sponsors    Sponsor[]
}

model Event {
  id          String     @id @default(cuid())
  editionId   String
  edition     Edition    @relation(fields: [editionId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  kind        EventKind  @default(OTRO)
  startsAt    DateTime
  endsAt      DateTime?
  venue       String?
  capacity    Int?
  priceCents  Int        @default(0) // 0 = gratis
  description String?    @db.Text
  coverUrl    String?
  speaker     String?
  isPublished Boolean    @default(false)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  reservations Reservation[]

  @@unique([editionId, slug])
  @@index([startsAt])
}

model Reservation {
  id          String            @id @default(cuid())
  editionId   String
  edition     Edition           @relation(fields: [editionId], references: [id], onDelete: Cascade)
  eventId     String?
  event       Event?            @relation(fields: [eventId], references: [id], onDelete: SetNull)

  name        String
  email       String
  phone       String?
  partySize   Int               @default(1)
  dietary     String?           // alergias adicionales (lactosa, frutos secos…)
  notes       String?           @db.Text
  status      ReservationStatus @default(PENDING)
  source      String?           // web | instagram | telefono | otro
  ipHash      String?
  userAgent   String?
  emailedAt   DateTime?
  cancelledAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([editionId, status])
  @@index([email])
}

model Sponsor {
  id          String       @id @default(cuid())
  editionId   String?
  edition     Edition?     @relation(fields: [editionId], references: [id], onDelete: SetNull)
  name        String
  slug        String       @unique
  logoUrl     String?
  websiteUrl  String?
  description String?      @db.Text
  tier        SponsorTier  @default(BRONZE)
  order       Int          @default(0)
  isPublished Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tier, order])
}

model Post {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  excerpt     String?    @db.Text
  contentMdx  String     @db.Text
  coverUrl    String?
  tags        String[]   @default([])
  authorId    String?
  author      User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  status      PostStatus @default(DRAFT)
  scheduledAt DateTime?
  publishedAt DateTime?
  seoTitle    String?
  seoDescription String? @db.Text
  ogImageUrl  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
}

model SiteSettings {
  id              String   @id @default(cuid())
  singleton       Boolean  @default(true) @unique // siempre true; fuerza una única fila
  festivalName    String   @default("Singlufest")
  tagline         String   @default("El festival sin gluten de Granada")
  contactEmail    String   @default("hola@singlufest.es")
  instagramUrl    String   @default("https://www.instagram.com/singlufest/")
  youtubeUrl      String?
  tiktokUrl       String?
  newsletterUrl   String?
  heroVideoUrl    String?
  heroPosterUrl   String?
  bookingsOpen    Boolean  @default(false)
  metaTitle       String   @default("Singlufest — Festival Sin Gluten de Granada")
  metaDescription String   @default("Showcookings, charlas, catas y mercado. Granada celebra la cocina sin gluten.")
  ogImageUrl      String?
  updatedAt       DateTime @updatedAt
}

model EmailSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  consent   Boolean  @default(true)
  unsubscribedAt DateTime?
  createdAt DateTime @default(now())
}

model Candidate {
  id             String   @id @default(cuid())
  slug           String   @unique
  number         String              // "01" .. "12" o lo que quieras
  chef           String              // "KIMCAKES"
  dish           String              // "La Reina"
  description    String   @db.Text   // pitch del plato
  longBio        String?  @db.Text   // bio del chef para la ficha
  price          Int      @default(0)  // en € enteros (0 = "por anunciar")
  bg             String   @default("from-brand-orange via-brand-tangerine to-brand-burn")
  badge          String?              // "Headliner", "Emergente"…
  websiteUrl     String?
  instagramUrl   String?
  imageUrl       String?              // foto del plato cuando llegue
  location       String?
  foundedYear    Int?
  isPublished    Boolean  @default(true)
  order          Int      @default(0) // orden en el cartel
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([order, isPublished])
}

enum GiveawayStatus {
  DRAFT
  ACTIVE
  CLOSED
  DRAWN
}

enum GiveawayEntrySource {
  WEB             // formulario en /sorteos/[slug]
  INSTAGRAM_TAG   // detectado por webhook Graph API
  INSTAGRAM_STORY // detectado por mention en story
  ADMIN           // añadido manualmente por admin
}

enum GiveawayEntryStatus {
  PENDING
  VERIFIED
  REJECTED
  WINNER
}

model Giveaway {
  id            String          @id @default(cuid())
  slug          String          @unique
  title         String
  shortPitch    String          @db.Text          // 1 frase pitch
  description   String          @db.Text          // descripción completa MDX/HTML simple
  prize         String          @db.Text
  imageUrl      String?
  rules         String[]        @default([])      // requisitos visibles ("Seguir @singlufest", etc.)
  hashtag       String?                            // sin # — ej. "SingluFestSorteo"
  mentionTarget String          @default("singlufest") // handle a mencionar (sin @)
  startsAt      DateTime        @default(now())
  endsAt        DateTime
  drawnAt       DateTime?
  winnerEntryId String?         @unique
  status        GiveawayStatus  @default(DRAFT)
  isPublished   Boolean         @default(false)
  maxEntries    Int?                               // null = sin límite
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  entries       GiveawayEntry[]
}

model GiveawayEntry {
  id            String              @id @default(cuid())
  giveawayId    String
  giveaway      Giveaway            @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  email         String
  name          String?
  igHandle      String              // sin @, en minúsculas
  sharedPostUrl String?
  source        GiveawayEntrySource @default(WEB)
  status        GiveawayEntryStatus @default(PENDING)
  verifiedAt    DateTime?
  verifiedBy    String?             // user id del admin que verificó
  rejectionReason String?
  ipHash        String?
  userAgent     String?
  igMediaId     String?             // id del post de IG si webhook lo detecta
  metadata      Json?               // datos extra (oembed, raw webhook)
  createdAt     DateTime            @default(now())
  notifiedAt    DateTime?           // si fue ganador y se le notificó

  @@unique([giveawayId, email])
  @@unique([giveawayId, igHandle])
  @@index([giveawayId, status])
  @@index([igHandle])
}

model Vote {
  id             String   @id @default(cuid())
  candidateSlug  String   // matches partner/[slug] o sponsor.slug
  voterToken     String   // hash(ip + cookie + secret) para evitar duplicados sin guardar PII
  userAgent      String?
  createdAt      DateTime @default(now())

  @@unique([candidateSlug, voterToken])
  @@index([candidateSlug])
  @@index([createdAt])
}

model AgentRun {
  id        String   @id @default(cuid())
  agent     String   // "redactor" | "analista" | "video-builder"
  status    String   // "ok" | "error"
  costUsd   Float?
  tokensIn  Int?
  tokensOut Int?
  output    String?  @db.Text
  errorMsg  String?  @db.Text
  ranAt     DateTime @default(now())

  @@index([agent, ranAt])
}
